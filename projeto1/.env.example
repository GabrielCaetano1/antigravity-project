# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_NAME=dbname

# Configurações de Segurança do JWT
# DICA: Para gerar uma chave segura no terminal, rode: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=sua_chave_secreta_jwt_aqui
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
